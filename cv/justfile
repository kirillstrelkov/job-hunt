set shell := ["bash", "-cu"]


mastercv := "./tmp/master_cv.md"
cvbody := "./private/parts/body.md"

default:
    @just --list

cfg-create:
    tools/.venv/bin/python tools/cfg.py --create

cfg-check path="":
    tools/.venv/bin/python tools/cfg.py --check {{ if path == "" { "" } else { "--path " + path } }}

check:
    tools/.venv/bin/python tools/process_cv.py --check {{ cvbody }}

fix:
    tools/.venv/bin/python tools/process_cv.py --fix {{ mastercv }}

combine:
    cat ./private/parts/header.md > {{ mastercv }}
    printf "\n" >> {{ mastercv }}
    cat {{ cvbody }} >> {{ mastercv }}
    printf "\n" >> {{ mastercv }}
    cat ./private/parts/footer.md >> {{ mastercv }}

run: check combine
    # fix
    tools/.venv/bin/python tools/process_cv.py --fix {{ mastercv }}

    # create text to tailor cv for job description
    /home/kirill/prj/gh/job-hunt/tools/prep_for_cv_tail/target/debug/prep_for_tail \
      --cv {{ mastercv }} \
      --prompt ./prompts/tailor.md \
      --jd ./tmp/jd.txt \
      --output ./tmp/prompt_to_tailor.md

    # evaluate match
    # cat ./prompt_match.md > "./tmp/prompt_to_match.md"
    # printf "\nCV:\n" >> "./tmp/prompt_to_match.md"
    # cat "./tmp/nvidia_gemini_cv.md" >> "./tmp/prompt_to_match.md"
    # printf "\nJob desription:\n" >> "./tmp/prompt_to_match.md"
    # cat "./tmp/nvidia.txt" >> "./tmp/prompt_to_match.md"

gui:
