    pandoc -V papersize=a4 -V geometry:margin=1.5cm "{{ folder }}/gen/cv.md" -o "{{ folder }}/gen/cvStrelkov.pdf"

prepare-llm folder:
    tools/.venv/bin/python tools/prepare_cv.py --llm-prompt {{ folder }}

