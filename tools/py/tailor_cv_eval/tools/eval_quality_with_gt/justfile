# Run Promptfoo prompt evaluation to compare baseline prompt vs candidate prompt
eval-prompts *args="":
    uv run python {{ justfile_directory() }}/run.py {{ args }}

# View Promptfoo prompt evaluation dashboard
view-promptfoo:
    npx promptfoo view

# Convert jupyter notebook to html
convert2html:
    uvx jupyter nbconvert ./result_analysis.ipynb --to html --output ./results/result_analysis.html --
