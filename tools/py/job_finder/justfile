set dotenv-path := "private/.env"
set dotenv-required := true

default:
    @just -l

# Run the full CV-to-job matching pipeline on URLs list
cli:
    uv run python cli/fetch_and_match.py --log-level DEBUG data/private/urls.yml

# Analyze a single job description from standard input
llm-check-jd model="":
    uv run python cli/check_jd.py {{ if model == "" { "" } else { "--model " + model } }}

# Review and update matching results from a CSV or ODF file
llm-review path:
    uv run python cli/llm_review.py --path {{ path }}

# Run the test suite
test:
    uv run pytest reviewer/llm_test.py

# Run linter and formatting checks
lint:
    uv run ruff format
    uv run ruff check --fix
    uv run ruff check

# Run Promptfoo prompt evaluation to compare baseline prompt vs candidate prompts
eval-prompts *args:
    uv run python promptfoo/run.py {{ args }}

# View Promptfoo prompt evaluation dashboard
view-promptfoo:
    npx promptfoo view
