{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Bash(uv *)",
      "Bash(just *)",
      "Bash(npm install *)"
    ],
    "deny": [
      "Read(.env)",
      "Write(**/.claude/**)",
      "Read(**/private/**)"
    ]
  }
}
